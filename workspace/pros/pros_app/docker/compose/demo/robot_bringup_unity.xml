<launch>
    <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher" output="screen">
        <param name="robot_description" value="$(command 'cat /workspace/demo/v6_unity.urdf')" />
    </node>

    <node name="scan_matcher" pkg="ros2_laser_scan_matcher" exec="laser_scan_matcher" output="screen">
        <param name="base_frame" value="base_footprint"/>
        <param name="publish_tf" value="true"/>
        <param name="publish_odom" value="odom"/>
    </node>
</launch>