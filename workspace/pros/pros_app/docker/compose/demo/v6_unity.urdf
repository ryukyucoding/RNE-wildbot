  <joint name="camera_to_optical_joint" type="fixed">
    <parent link="camera"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>
  <link name="laser"/>
  <joint name="lidar_to_laser" type="fixed">
    <parent link="LiDAR_v1_1"/>
    <child link="laser"/>
    <origin xyz="0 0 0.0285" rpy="0 0 0"/>
  </joint>
</robot>

